// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Car {
  id            String   @id @default(cuid())
  name          String
  description   String?
  category      String   // coupe, electric, convertible, luxury, suv, sedan
  brand         String
  model         String
  year          Int
  fuelType      String   // petrol, diesel, electric, hybrid
  transmission  String   // automatic, manual
  seats         Int
  mileage       String?
  hourlyRate    Float
  dailyRate     Float
  weeklyRate    Float?
  monthlyRate   Float?
  images        String[] // Array of image URLs
  available     Boolean  @default(true)
  featured      Boolean  @default(false)
  gameDrive     Boolean  @default(false) // For Akagera Game Drive
  specifications Json?   // Additional specs as JSON
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookings      Booking[]

  @@index([category])
  @@index([available])
  @@index([featured])
  @@index([gameDrive])
}

model Booking {
  id            String   @id @default(cuid())
  carId         String
  car           Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  customerName  String
  customerEmail String
  customerPhone String

  pickupDate    DateTime
  returnDate    DateTime
  pickupLocation String
  returnLocation String?

  totalCost     Float
  status        String   @default("pending") // pending, confirmed, completed, cancelled

  specialRequests String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([carId])
  @@index([status])
  @@index([customerEmail])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    String   @default("new") // new, read, replied
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Manager {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hashed password
  name      String
  role      String   @default("manager") // manager, super_admin
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model BlogPost {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique // URL-friendly version of title
  excerpt         String   // Short description for previews
  content         String   @db.Text // Full blog content (supports HTML/Markdown)
  featuredImage   String?  // Main image URL
  author          String   @default("Kigali Car Hire Team")
  category        String   // car-tips, travel-guides, company-news, rwanda-tourism, car-maintenance
  tags            String[] // SEO keywords: car rental Rwanda, Kigali tourism, etc.
  metaTitle       String?  // SEO meta title
  metaDescription String?  // SEO meta description
  metaKeywords    String[] // SEO keywords array
  published       Boolean  @default(false)
  featured        Boolean  @default(false) // Show on homepage
  views           Int      @default(0)
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@index([published])
  @@index([featured])
  @@index([publishedAt])
}

model BookingRequest {
  id                    String   @id @default(cuid())

  // Trip Details
  pickupDate            String
  pickupTime            String
  returnDate            String
  returnTime            String
  pickupLocation        String
  dropoffLocation       String?

  // Preferences
  carType               String?
  transmission          String?
  seats                 String?
  budget                String?
  purpose               String?
  additionalRequirements String?  @db.Text

  // Contact Information
  fullName              String
  email                 String
  phone                 String
  whatsapp              String?

  // Status and management
  status                String   @default("new") // new, contacted, quoted, converted, cancelled
  assignedCarId         String?  // If a car is assigned later
  notes                 String?  @db.Text // Admin notes

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@index([createdAt])
}
